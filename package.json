{
  "name": "copilot-eval",
  "version": "1.1.0",
  "description": "Eval framework for Copilot CLI skills",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "copilot-eval": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sebastienlevert/skill-evals.git"
  },
  "keywords": [
    "copilot",
    "eval",
    "cli",
    "github-copilot",
    "testing",
    "evaluation"
  ],
  "author": "Sebastien Levert",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && cp -r src/templates dist/",
    "build:binary": "node scripts/build-binary.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "node dist/cli.js run",
    "init": "node dist/cli.js init"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "yaml": "^2.8.2"
  }
}
