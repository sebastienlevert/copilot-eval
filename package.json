{
  "name": "copilot-eval",
  "version": "1.0.0",
  "description": "Eval framework for Copilot CLI skills",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "copilot-eval": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/templates dist/",
    "build:binary": "node scripts/build-binary.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "node dist/cli.js run",
    "eval:m365": "node dist/cli.js run --skill ~/.copilot/skills/m365-agent-developer",
    "init": "node dist/cli.js init"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
